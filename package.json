{
  "name": "modelinfo",
  "version": "0.1.0",
  "description": "A fast CLI to explore AI model capabilities, pricing, limits, and provider metadata.",
  "keywords": [
    "ai",
    "bun",
    "cli",
    "llm",
    "metadata",
    "modelinfo",
    "models",
    "openai",
    "providers",
    "typescript"
  ],
  "homepage": "https://github.com/zerob13/modelinfo-cli#readme",
  "bugs": {
    "url": "https://github.com/zerob13/modelinfo-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerob13/modelinfo-cli.git"
  },
  "license": "MIT",
  "author": "zerob13",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "modelinfo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "seed",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:seed": "tsx scripts/build-seed.ts",
    "dev": "tsx watch src/cli.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build:seed && npm run build",
    "release": "tsx scripts/release.ts",
    "start": "tsx dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fuse.js": "^7.1.0",
    "semver": "^7.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.14",
    "@types/semver": "^7.5.8",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.19",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
