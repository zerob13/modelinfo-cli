{
  "name": "modelinfo",
  "version": "0.1.0",
  "description": "A fast CLI to explore AI model capabilities, pricing, limits, and provider metadata.",
  "type": "module",
  "bin": {
    "modelinfo": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "seed",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:seed": "tsx scripts/build-seed.ts",
    "dev": "tsx watch src/cli.ts",
    "start": "tsx dist/cli.js",
    "test": "vitest run",
    "lint": "eslint .",
    "prepack": "npm run build:seed && npm run build"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fuse.js": "^7.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
